# --- required ---
WBRAW=/tmp/gfs-mirror/raw
WBPROC=/tmp/gfs-mirror/proc

# --- GFS product selection ---
# Grid: 1p00 (1.0 degree, 3-hourly) or 0p25 (0.25 degree, hourly 0-120)
GFSM_GRID=1p00

# Lead-hour sampling schedule.
# Format: comma-separated "start-end:step" ranges.
# Each range's start is excluded if the previous range already emitted it.
# Default matches what 1p00 physically publishes (3-hourly for first 48h, 6-hourly after).
# For literal task spec (requires 0p25): 0-12:2,12-48:3,48-192:6
GFSM_SCHEDULE=0-48:3,48-192:6

# --- concurrency ---
GFSM_DOWNLOAD_CONCURRENCY=8
GFSM_PROCESS_CONCURRENCY=
# ^ blank => os.cpu_count()

# --- timing / retries ---
GFSM_POLL_INTERVAL_SEC=60
GFSM_PUBLISH_LAG_MINUTES=210
GFSM_MAX_FILE_RETRIES=20
GFSM_CYCLE_TIMEOUT_HOURS=5

# --- misc ---
GFSM_LOG_LEVEL=INFO
